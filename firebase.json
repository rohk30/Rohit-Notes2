{
  "hosting": {
    "target": "rohit-notes",
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|wasm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=31536000"
          }
        ]
      },
      {
        "source": "index.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "renewedvigour-mynotes",
          "appId": "1:532749228928:android:0a6d87e656eb43ae72bf65",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "renewedvigour-mynotes",
          "configurations": {
            "android": "1:532749228928:android:0a6d87e656eb43ae72bf65",
            "ios": "1:532749228928:ios:0893cd80ca2fc05372bf65"
          }
        }
      }
    }
  }
}
